{
  "name": "basecamp",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "firebase emulators:exec --only firestore,auth 'vitest run --config vitest.integration.config.js'",
    "build:prod": "vite build --mode prod",
    "deploy:dev": "npm run build && firebase deploy --only hosting --project dev",
    "deploy:prod": "node scripts/check-prod-env.mjs && npm run build:prod && firebase deploy --only hosting --project prod",
    "deploy:rules:dev": "firebase deploy --only firestore:rules,firestore:indexes --project dev",
    "deploy:rules:prod": "firebase deploy --only firestore:rules,firestore:indexes --project prod",
    "deploy": "echo 'Use deploy:dev or deploy:prod explicitly' && exit 1"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "firebase": "^12.14.0",
    "pinia": "^2.3.1",
    "vue": "^3.5.16",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^4.5.1",
    "vuetify": "^3.8.4",
    "workbox-window": "^7.3.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^0.21.1",
    "vite-plugin-vuetify": "^2.1.1",
    "vitest": "^4.1.8"
  }
}
