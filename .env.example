VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to true to connect to the local Firebase emulator instead of the cloud project.
# Add VITE_USE_EMULATOR=true to .env.local (gitignored) on your machine.
VITE_USE_EMULATOR=false

# Firebase App Check reCAPTCHA v3 site key. Optional — App Check is skipped when
# this is unset or when VITE_USE_EMULATOR=true. Get a per-project site key from
# Firebase Console → Build → App Check. Use the dev project's key in .env and the
# prod project's key in .env.prod.
VITE_RECAPTCHA_SITE_KEY=

# ---
# For production deploys, create a .env.prod file (also gitignored) with the same
# keys pointing to the prod Firebase project (basecamp-app-prod).
# Vite picks it up automatically when you run: vite build --mode prod
# ---
